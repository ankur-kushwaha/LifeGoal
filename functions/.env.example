# Do not put OPENROUTER_API_KEY in .env — it conflicts with Firebase secrets on deploy.
#
# Production:
#   npx -y firebase-tools@latest functions:secrets:set OPENROUTER_API_KEY
#
# Local emulator:
#   Copy your key to functions/.secret.local (gitignored):
#   OPENROUTER_API_KEY=your-openrouter-api-key-here
