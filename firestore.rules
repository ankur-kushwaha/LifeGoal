rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userFamilyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
    }

    function isFamilyMember(familyId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isFamilyAdmin(familyId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/families/$(familyId)).data.adminId == request.auth.uid;
    }

    function isValidOptionalNumber(field) {
      return !(field in request.resource.data) ||
        request.resource.data[field] is number;
    }

    function isValidGoal(data) {
      return data.keys().hasAll([
          'id', 'name', 'account', 'targetCost',
          'startDate', 'targetDate', 'currentSavings'
        ]) &&
        data.id is string && data.id.size() > 0 && data.id.size() <= 64 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
        data.account is string && data.account.size() > 0 && data.account.size() <= 100 &&
        data.targetCost is number && data.targetCost >= 0 &&
        data.startDate is string && data.startDate.size() <= 40 &&
        data.targetDate is string && data.targetDate.size() <= 40 &&
        data.currentSavings is number && data.currentSavings >= 0 &&
        isValidOptionalNumber('expectedReturn') &&
        isValidOptionalNumber('inflationRate') &&
        data.keys().hasOnly([
          'id', 'name', 'account', 'targetCost',
          'startDate', 'targetDate', 'currentSavings',
          'expectedReturn', 'inflationRate'
        ]);
    }

    function isValidFamilySettings(data) {
      return (!('globalInflation' in data) || data.globalInflation is number) &&
        (!('globalReturn' in data) || data.globalReturn is number) &&
        (!('today' in data) || (data.today is string && data.today.size() <= 40));
    }

    function isValidUserProfile(data) {
      return data.keys().hasOnly(['familyId', 'email', 'displayName', 'globalInflation', 'globalReturn', 'today']) &&
        (!('familyId' in data) || data.familyId is string) &&
        (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
        (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
        isValidFamilySettings(data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);

      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['name', 'adminId', 'createdAt']) &&
        request.resource.data.adminId == request.auth.uid;
      allow update: if (
          (isFamilyAdmin(familyId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])) ||
          (isFamilyMember(familyId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['globalInflation', 'globalReturn', 'today']))
        ) && isValidFamilySettings(request.resource.data);
      allow delete: if isFamilyAdmin(familyId);

      match /members/{memberId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isAuthenticated() && (
          (memberId == request.auth.uid && request.resource.data.role in ['admin', 'member']) ||
          isFamilyAdmin(familyId)
        );
        allow update: if isFamilyAdmin(familyId);
        allow delete: if isFamilyAdmin(familyId) &&
          memberId != get(/databases/$(database)/documents/families/$(familyId)).data.adminId;
      }

      match /goals/{goalId} {
        allow read: if isFamilyMember(familyId);
        allow create, update: if isFamilyMember(familyId) && isValidGoal(request.resource.data);
        allow delete: if isFamilyMember(familyId);
      }

      match /invites/{inviteId} {
        allow read: if isFamilyAdmin(familyId);
        allow create, update: if isFamilyAdmin(familyId);
        allow delete: if isFamilyAdmin(familyId);
      }
    }

    match /invites/{email} {
      allow read: if isAuthenticated() &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == email;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == email;
      allow delete: if false;
    }
  }
}
